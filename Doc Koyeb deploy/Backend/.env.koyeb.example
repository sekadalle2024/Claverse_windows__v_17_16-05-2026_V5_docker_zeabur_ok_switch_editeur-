# Configuration Koyeb pour Clara Backend
# Copier ce fichier en .env et remplir les valeurs

# Configuration serveur
HOST=0.0.0.0
PORT=5000
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# OpenAI API (optionnel - pour LightRAG)
OPENAI_API_KEY=your-openai-api-key

# Neo4j Configuration (optionnel - pour LightRAG)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Google API (optionnel - pour Google Drive proxy)
GOOGLE_API_KEY=your-google-api-key

# N8N Configuration (optionnel)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# Autres configurations
NUMPY_ALLOCATE_DEFAULT=0
