{
  "manifest_version": 3,
  "name": "Table Selector Detective - Claraverse",
  "version": "1.0.0",
  "description": "Détecte toutes les tables dans le DOM du chat et affiche leurs sélecteurs CSS (Claraverse / Flowise compatible)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Table Selector Detective"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
